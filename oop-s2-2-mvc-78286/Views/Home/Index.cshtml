@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center mt-5">
    <h1 class="display-4">Food Safety Tracker</h1>
    <hr class="w-25 mx-auto" />

    @if (SignInManager.IsSignedIn(User))
    {
        // --- LOGGED IN VIEW ---
        <div class="card shadow-sm mx-auto" style="max-width: 500px;">
            <div class="card-body">
                <h3 class="text-success">Welcome Back!</h3>
                <p class="lead">Logged in as: <strong>@User.Identity?.Name</strong></p>
                
                <div class="d-grid gap-2 d-md-block mt-4">
                    <a class="btn btn-primary" asp-controller="Dashboard" asp-action="Index">Go to Dashboard</a>
                    <form class="form-inline d-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button type="submit" class="btn btn-outline-danger">Logout</button>
                    </form>
                </div>
            </div>
        </div>
    }
    else
    {
        // --- LOGGED OFF VIEW ---
        <div class="py-5">
            <p class="lead">Please log in to manage inspections and follow-up actions.</p>
            <div class="mt-4">
                <a class="btn btn-lg btn-primary px-5" asp-area="Identity" asp-page="/Account/Login">Login</a>
                <p class="mt-3 text-muted">Use the credentials provided in your seed data</p>
            </div>
        </div>
    }

    <div class="mt-5">
        <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
    </div>
</div>