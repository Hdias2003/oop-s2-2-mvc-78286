@model FoodSafety.Domain.Models.Premises

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Premises</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Name)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Name)</dd>
        
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Address)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Address)</dd>
        
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Town)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Town)</dd>
        
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.RiskRating)</dt>
        <dd class="col-sm-10">
            <span class="badge @(Model.RiskRating.ToString() == "High" ? "bg-danger" : "bg-info")">
                @Html.DisplayFor(model => model.RiskRating)
            </span>
        </dd>
    </dl>
</div>

<hr />

<div class="mt-4">
    <h4>Inspection History</h4>
    @if (Model.Inspections != null && Model.Inspections.Any())
    {
        <table class="table table-bordered table-striped mt-3">
            <thead class="table-dark">
                <tr>
                    <th>Date</th>
                    <th>Score</th>
                    <th>Outcome</th>
                    <th>Notes</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var inspection in Model.Inspections.OrderByDescending(i => i.InspectionDate))
                {
                    <tr>
                        <td>@inspection.InspectionDate.ToShortDateString()</td>
                        
                        <td class="fw-bold">@inspection.Score</td>

                        <td>
                            @if (inspection.Outcome?.Equals("Pass", StringComparison.OrdinalIgnoreCase) == true)
                            {
                                <span class="badge bg-success">Pass</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">@inspection.Outcome</span>
                            }
                        </td>

                        <td style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@inspection.Notes">
                            @(string.IsNullOrEmpty(inspection.Notes) ? "No notes provided" : inspection.Notes)
                        </td>
                        
                        <td>
                            <a asp-controller="Inspections" asp-action="Details" asp-route-id="@inspection.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-eye"></i> View Report
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-secondary">
            No inspections recorded for this premises yet.
        </div>
    }
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Edit Premises</a> |
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>