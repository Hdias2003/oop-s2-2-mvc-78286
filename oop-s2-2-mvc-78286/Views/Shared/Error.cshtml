@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center mt-5">
    <h1 class="display-4 text-danger">Oops! Something went wrong.</h1>
    
    <div class="alert alert-warning mt-4 d-inline-block p-4" style="max-width: 80%;">
        <h4 class="alert-heading">Error Detail:</h4>
        <p class="mb-0">@Model.Message</p>
    </div>

    <div class="mt-4">
        <div class="card bg-light d-inline-block p-3">
            <p class="text-muted mb-1">Our technical team has been notified via <strong>Serilog</strong>.</p>
            @if (Model.ShowRequestId)
            {
                <p class="mb-0"><small>Reference ID: <span class="badge bg-secondary">@Model.RequestId</span></small></p>
            }
        </div>
    </div>

    <div class="mt-5">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">Return to Dashboard</a>
    </div>
</div>