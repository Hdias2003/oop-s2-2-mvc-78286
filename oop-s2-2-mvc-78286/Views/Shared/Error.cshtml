@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center mt-5">
    <h1 class="display-4 text-danger"><i class="bi bi-exclamation-triangle"></i> Oops! Something went wrong.</h1>
    <p class="lead">We've encountered an unexpected issue while processing your request.</p>
    
    <div class="alert alert-secondary d-inline-block mt-3">
        <p><strong>Don't worry:</strong> Our technical team has been notified via our <strong>Serilog</strong> monitoring system.</p>
        @if (Model.ShowRequestId)
        {
            <p><small>Reference ID: <code>@Model.RequestId</code></small></p>
        }
    </div>

    <div class="mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">Return to Dashboard</a>
    </div>
</div>