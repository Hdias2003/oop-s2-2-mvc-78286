@model FoodSafety.Domain.Models.FollowUp

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>
<h4>FollowUp</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="InspectionId" class="control-label">Inspection Reference</label>
                <select asp-for="InspectionId" id="InspectionSelect" class="form-control" asp-items="ViewBag.InspectionId"></select>
                <span asp-validation-for="InspectionId" class="text-danger"></span>
            </div>

            <div id="InspectionInfo" class="alert alert-info mb-3">
                <strong>Premises:</strong> <span id="infoPremise">Loading...</span><br />
                <strong>Inspection Date:</strong> <span id="infoDate">Loading...</span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DueDate" class="control-label"></label>
                <input asp-for="DueDate" type="date" class="form-control" />
                <span asp-validation-for="DueDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" id="StatusSelect" class="form-control">
                    <option value="Open">Open</option>
                    <option value="Closed">Closed</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="form-group mb-3" id="ClosedDateGroup">
                <label asp-for="ClosedDate" class="control-label"></label>
                <input asp-for="ClosedDate" id="ClosedDateInput" type="date" class="form-control" />
                <span asp-validation-for="ClosedDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // --- Logic for Status and Closed Date ---
        function toggleClosedDate() {
            const status = document.getElementById('StatusSelect').value;
            const dateInput = document.getElementById('ClosedDateInput');
            const group = document.getElementById('ClosedDateGroup');

            if (status === 'Closed') {
                group.style.opacity = "1";
                dateInput.required = true;
                if (!dateInput.value) {
                    dateInput.value = new Date().toISOString().split('T')[0];
                }
            } else {
                dateInput.value = "";
                dateInput.required = false;
                group.style.opacity = "0.5";
            }
        }

        // --- Logic for Inspection Parsing ---
        function updateInspectionInfo() {
            const select = document.getElementById('InspectionSelect');
            if (!select || select.selectedIndex === -1) return;
            
            const selectedText = select.options[select.selectedIndex].text;
            const infoBox = document.getElementById('InspectionInfo');
            
            if (select.value && selectedText.includes(' - ')) {
                try {
                    const parts = selectedText.split(' - ');
                    const premiseAndDate = parts[1].split(' (');
                    
                    document.getElementById('infoPremise').innerText = premiseAndDate[0];
                    document.getElementById('infoDate').innerText = premiseAndDate[1].replace(')', '');
                    infoBox.classList.remove('d-none');
                } catch (e) {
                    infoBox.classList.add('d-none');
                }
            } else {
                infoBox.classList.add('d-none');
            }
        }

        // --- Event Listeners ---
        document.addEventListener('DOMContentLoaded', function() {
            // Setup Status events
            const statusSelect = document.getElementById('StatusSelect');
            statusSelect.addEventListener('change', toggleClosedDate);
            toggleClosedDate(); // Run on load

            // Setup Inspection events
            const inspectSelect = document.getElementById('InspectionSelect');
            inspectSelect.addEventListener('change', updateInspectionInfo);
            updateInspectionInfo(); // Run on load
        });
                function toggleClosedDate() {
            const status = document.getElementById('StatusSelect').value;
            const dateInput = document.getElementById('ClosedDateInput');
            const dueDateInput = document.querySelector('input[name="DueDate"]');
            const group = document.getElementById('ClosedDateGroup');

            if (status === 'Closed') {
                group.style.opacity = "1";
                dateInput.required = true;
        
                // Simple UI Warning
                dateInput.addEventListener('change', function() {
                    if (dueDateInput.value && this.value < dueDateInput.value) {
                        alert("Warning: Closed Date should not be before the Due Date.");
                        this.classList.add("is-invalid");
                    } else {
                        this.classList.remove("is-invalid");
                    }
                });

                if (!dateInput.value) {
                    dateInput.value = new Date().toISOString().split('T')[0];
                }
            } else {
                dateInput.value = "";
                dateInput.required = false;
                group.style.opacity = "0.5";
            }
        }
    </script>
}